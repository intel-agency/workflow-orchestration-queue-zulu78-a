# OS-APOW Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# GitHub Configuration (Required)
# =============================================================================

# GitHub Personal Access Token or App Installation Token
# Required scopes: repo, issues, pull_requests
OS_APOW_GITHUB_TOKEN=your-github-token-here

# GitHub organization name (for polling)
OS_APOW_GITHUB_ORG=your-org-name

# Target repository in owner/repo format
OS_APOW_GITHUB_REPO=your-org/your-repo

# Bot account login for distributed locking (optional but recommended)
OS_APOW_SENTINEL_BOT_LOGIN=your-bot-account

# =============================================================================
# Webhook Configuration (Required for Notifier)
# =============================================================================

# HMAC secret for webhook signature validation
# Generate with: openssl rand -hex 32
OS_APOW_WEBHOOK_SECRET=your-webhook-secret-here

# Port for the webhook receiver (default: 8000)
OS_APOW_WEBHOOK_PORT=8000

# =============================================================================
# Sentinel Configuration
# =============================================================================

# Unique identifier for this sentinel instance
OS_APOW_SENTINEL_ID=sentinel-001

# Interval between GitHub API polling cycles (seconds)
OS_APOW_POLL_INTERVAL_SECONDS=60

# Interval between heartbeat comments (seconds)
OS_APOW_HEARTBEAT_INTERVAL_SECONDS=300

# =============================================================================
# DevContainer Configuration
# =============================================================================

# Docker network for worker isolation
OS_APOW_DEVCONTAINER_NETWORK=os-apow-network

# CPU limit per worker container
OS_APOW_DEVCONTAINER_CPU_LIMIT=2.0

# Memory limit per worker container
OS_APOW_DEVCONTAINER_MEMORY_LIMIT=4g

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
OS_APOW_LOG_LEVEL=INFO

# Log format: json (production) or text (development)
OS_APOW_LOG_FORMAT=json
